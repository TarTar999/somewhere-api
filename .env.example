APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SMS Service (SMSVAS)
SMSVAS_USER=
SMSVAS_PASSWORD=
SMSVAS_SENDER_ID=Somewhere

# Fapshi Payment Gateway
# Use FAK_TEST_ prefix for sandbox mode
FAPSHI_API_USER=
FAPSHI_API_KEY=
FAPSHI_WEBHOOK_SECRET=
FAPSHI_PROOF_OF_LOCATION_PRICE=1000

# Proof of Location Settings
PROOF_OF_LOCATION_VALIDITY_MONTHS=3

# Account Settings
ACCOUNT_DELETION_GRACE_PERIOD_DAYS=30

# KYC Settings
KYC_VALIDITY_MONTHS=12

# Company Information (for invoices)
COMPANY_NAME=Somewhere
COMPANY_ADDRESS="Douala, Cameroun"
COMPANY_PHONE="+237 600 000 000"
COMPANY_EMAIL=contact@somewhere.cm

# App Share & Deep Linking
# Set to 'development' or 'production'
APP_SHARE_MODE=development
# Deep link scheme for production (e.g., somewhereapp://)
APP_DEEP_LINK_SCHEME=somewhereapp
# Expo URL for development (e.g., exp://192.168.1.179:8081)
APP_EXPO_URL=exp://192.168.1.179:8081
# Public URL for sharing (the URL users will see)
# Development: http://192.168.1.179:8000
# Production: https://www.api.somewhere-app.com
APP_SHARE_URL=http://192.168.1.179:8000
# App Store URLs (when published)
APP_STORE_IOS_URL=
APP_STORE_ANDROID_URL=
# Logo URL for social sharing
APP_LOGO_URL="${APP_SHARE_URL}/images/logo-somewhere.png"
